<!DOCTYPE html>
<html lang="te">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Manohar Royal Restaurant & Daba</title>
    <!-- Ultra-Premium Luxury Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Cinzel:wght@400;600;700;900&family=Marcellus&family=Montserrat:wght@300;400;500;600&display=swap" rel="stylesheet">
    <style>
        :root {
            --royal-gold: linear-gradient(135deg, #f3e7c4 0%, #e5c158 50%, #aa8214 100%);
            --gold-text: #e5c158;
            --gold-light: #fff4d4;
            --deep-black: #08090c;
            --premium-card: rgba(22, 25, 34, 0.7);
            --gold-border: rgba(229, 193, 88, 0.35);
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Montserrat', sans-serif;
            background-color: var(--deep-black);
            background-image: radial-gradient(circle at 50% 0%, #161a24 0%, #08090c 80%);
            color: #f1f5f9;
            overflow-x: hidden;
        }

        /* --- ROYAL INTRO SPLASH SCREEN --- */
        #welcome-screen {
            position: fixed;
            top: 0;
            left: 0;
            width: 100vw;
            height: 100vh;
            background: #08090c;
            display: flex;
            justify-content: center;
            align-items: center;
            z-index: 9999;
            transition: all 1.2s cubic-bezier(0.85, 0, 0.15, 1);
        }

        .welcome-geometry {
            position: relative;
            padding: 80px 60px;
            text-align: center;
            background: linear-gradient(135deg, rgba(20,24,33,0.9) 0%, rgba(10,11,15,0.95) 100%);
            border: 1px solid var(--gold-border);
            box-shadow: 0 30px 70px rgba(0,0,0,0.8), inset 0 0 40px rgba(229, 193, 88, 0.08);
            max-width: 700px;
            width: 90%;
        }

        /* Royal Corner Ornaments */
        .corner {
            position: absolute;
            width: 25px;
            height: 25px;
            border: 3px solid #e5c158;
        }
        .top-left { top: 20px; left: 20px; border-right: 0; border-bottom: 0; }
        .top-right { top: 20px; right: 20px; border-left: 0; border-bottom: 0; }
        .bottom-left { bottom: 20px; left: 20px; border-right: 0; border-top: 0; }
        .bottom-right { bottom: 20px; right: 20px; border-left: 0; border-top: 0; }

        .royal-crest {
            font-family: 'Cinzel', serif;
            font-weight: 300;
            color: var(--gold-text);
            font-size: 14px;
            letter-spacing: 10px;
            text-transform: uppercase;
            margin-bottom: 25px;
        }

        .rest-title {
            font-family: 'Cinzel', serif;
            font-weight: 700;
            font-size: 54px;
            background: var(--royal-gold);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            letter-spacing: 6px;
            text-transform: uppercase;
            margin-bottom: 10px;
        }

        .rest-subtitle {
            font-family: 'Marcellus', serif;
            font-size: 14px;
            color: #94a3b8;
            letter-spacing: 5px;
            text-transform: uppercase;
            margin-bottom: 50px;
        }

        .luxury-btn {
            font-family: 'Cinzel', serif;
            font-weight: 600;
            background: transparent;
            color: var(--gold-text);
            border: 1px solid var(--gold-text);
            padding: 16px 45px;
            font-size: 14px;
            letter-spacing: 4px;
            text-transform: uppercase;
            cursor: pointer;
            position: relative;
            overflow: hidden;
            transition: all 0.4s ease;
        }

        .luxury-btn:hover {
            color: #000;
            background: var(--royal-gold);
            box-shadow: 0 0 30px rgba(229, 193, 88, 0.4);
            border-color: transparent;
        }

        /* --- MAIN PREMIUM INTERFACE --- */
        #main-content {
            display: none;
            opacity: 0;
            transition: opacity 1.2s ease-in;
        }

        header {
            text-align: center;
            padding: 100px 20px 60px;
            position: relative;
        }

        header::after {
            content: '❖';
            color: var(--gold-text);
            display: block;
            margin-top: 20px;
            font-size: 18px;
            letter-spacing: 0;
        }

        header h1 {
            font-family: 'Cinzel', serif;
            font-weight: 700;
            font-size: 44px;
            background: var(--royal-gold);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            letter-spacing: 4px;
        }

        header p {
            font-family: 'Marcellus', serif;
            color: #94a3b8;
            letter-spacing: 4px;
            font-size: 13px;
            text-transform: uppercase;
            margin-top: 10px;
        }

        .header-contacts {
            font-size: 13px;
            color: var(--gold-text);
            margin-top: 15px;
            font-weight: 500;
            letter-spacing: 2px;
        }

        /* --- PREMIUM MENU LUXURY CARDS --- */
        .menu-wrapper {
            max-width: 1200px;
            margin: 40px auto 100px;
            padding: 0 25px;
        }

        .menu-section {
            background: var(--premium-card);
            border: 1px solid var(--gold-border);
            border-radius: 8px;
            padding: 45px;
            margin-bottom: 50px;
            backdrop-filter: blur(15px);
            box-shadow: 0 20px 40px rgba(0,0,0,0.3);
        }

        .section-header {
            font-family: 'Cinzel', serif;
            color: var(--gold-text);
            font-size: 24px;
            font-weight: 600;
            letter-spacing: 3px;
            text-transform: uppercase;
            margin-bottom: 35px;
            display: flex;
            align-items: center;
        }

        .section-header::after {
            content: '';
            flex: 1;
            height: 1px;
            background: linear-gradient(to right, var(--gold-border), transparent);
            margin-left: 20px;
        }

        .grid-container {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(480px, 1fr));
            gap: 25px 50px;
        }

        @media (max-width: 768px) {
            .grid-container { grid-template-columns: 1fr; }
            .menu-section { padding: 30px 20px; }
            .rest-title { font-size: 38px; }
            header h1 { font-size: 32px; }
        }

        .menu-row {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 12px 15px;
            background: rgba(255, 255, 255, 0.02);
            border-left: 2px solid transparent;
            transition: all 0.3s ease;
        }

        .menu-row:hover {
            background: rgba(229, 193, 88, 0.05);
            border-left-color: var(--gold-text);
            transform: translateX(5px);
        }

        .dish-name {
            font-size: 15px;
            color: #e2e8f0;
            font-weight: 500;
            letter-spacing: 0.5px;
        }

        .menu-row:hover .dish-name {
            color: var(--gold-light);
        }

        .dish-price {
            font-family: 'Marcellus', serif;
            color: var(--gold-text);
            font-weight: 600;
            font-size: 17px;
        }

        footer {
            text-align: center;
            padding: 50px;
            color: #64748b;
            font-size: 12px;
            letter-spacing: 2px;
            border-top: 1px solid var(--gold-border);
            font-family: 'Marcellus', serif;
        }
    </style>
</head>
<body>

    <!-- LUXURY SPLASH SCREEN -->
    <div id="welcome-screen">
        <div class="welcome-geometry">
            <div class="corner top-left"></div>
            <div class="corner top-right"></div>
            <div class="corner bottom-left"></div>
            <div class="corner bottom-right"></div>
            
            <div class="royal-crest">The Fine Dine Experience</div>
            <div class="rest-title">Manohar</div>
            <div class="rest-subtitle">Family Restaurant & Daba</div>
            <button class="luxury-btn" onclick="openMenu()">Enter Palace Menu</button>
        </div>
    </div>

    <!-- MAIN INTERFACE -->
    <div id="main-content">
        <header>
            <h1>MANOHAR RESTAURANT & DABA</h1>
            <p>Veg & Non Veg Specialties • Indian | Chinese | Tandoori</p>
            <div class="header-contacts">RESERVATIONS & ORDERS: 📞 9959544287 | 8309686838</div>
        </header>

        <div class="menu-wrapper">

            <!-- CHICKEN STARTERS -->
            <div class="menu-section">
                <div class="section-header">Elite Chicken Starters</div>
                <div class="grid-container">
                    <div class="menu-row"><span class="dish-name">Chilly Chicken</span><span class="dish-price">₹240</span></div>
                    <div class="menu-row"><span class="dish-name">Chicken 65</span><span class="dish-price">₹240</span></div>
                    <div class="menu-row"><span class="dish-name">Chicken Manchuria</span><span class="dish-price">₹240</span></div>
                    <div class="menu-row"><span class="dish-name">Chicken 555</span><span class="dish-price">₹290</span></div>
                    <div class="menu-row"><span class="dish-name">Garlic Chicken</span><span class="dish-price">₹290</span></div>
                    <div class="menu-row"><span class="dish-name">Ginger Chicken</span><span class="dish-price">₹290</span></div>
                    <div class="menu-row"><span class="dish-name">Lemon Chicken</span><span class="dish-price">₹290</span></div>
                    <div class="menu-row"><span class="dish-name">Boneless Chicken Roast</span><span class="dish-price">₹290</span></div>
                    <div class="menu-row"><span class="dish-name">Chicken Drumstick</span><span class="dish-price">₹300</span></div>
                    <div class="menu-row"><span class="dish-name">Pepper Chicken</span><span class="dish-price">₹290</span></div>
                    <div class="menu-row"><span class="dish-name">Chicken Lollypop (4 Pcs)</span><span class="dish-price">₹280</span></div>
                    <div class="menu-row"><span class="dish-name">Chicken Majestic</span><span class="dish-price">₹290</span></div>
                    <div class="menu-row"><span class="dish-name">Dragon Chicken</span><span class="dish-price">₹300</span></div>
                    <div class="menu-row"><span class="dish-name">Tandoori Chicken (Full)</span><span class="dish-price">₹550</span></div>
                    <div class="menu-row"><span class="dish-name">Tandoori Chicken (Half)</span><span class="dish-price">₹300</span></div>
                    <div class="menu-row"><span class="dish-name">Chicken Tikka Kabab</span><span class="dish-price">₹290</span></div>
                    <div class="menu-row"><span class="dish-name">Achari Kabab</span><span class="dish-price">₹300</span></div>
                    <div class="menu-row"><span class="dish-name">Malai Kabab</span><span class="dish-price">₹320</span></div>
                    <div class="menu-row"><span class="dish-name">Hariyali Kabab</span><span class="dish-price">₹290</span></div>
                    <div class="menu-row"><span class="dish-name">Kalami Kabab (4 Pcs)</span><span class="dish-price">₹340</span></div>
                    <div class="menu-row"><span class="dish-name">Tangidi Kabab (3 Pcs)</span><span class="dish-price">₹330</span></div>
                </div>
            </div>

            <!-- NON-VEG STARTERS (FISH, PRAWNS, MUTTON) -->
            <div class="menu-section">
                <div class="section-header">Seafood & Mutton Starters</div>
                <div class="grid-container">
                    <div class="menu-row"><span class="dish-name">Apollo Fish</span><span class="dish-price">₹330</span></div>
                    <div class="menu-row"><span class="dish-name">Chilly Fish</span><span class="dish-price">₹320</span></div>
                    <div class="menu-row"><span class="dish-name">Fish Manchuria</span><span class="dish-price">₹320</span></div>
                    <div class="menu-row"><span class="dish-name">Fish Fry (Andhra Style)</span><span class="dish-price">₹310</span></div>
                    <div class="menu-row"><span class="dish-name">Chilly Prawns</span><span class="dish-price">₹330</span></div>
                    <div class="menu-row"><span class="dish-name">Prawns 65</span><span class="dish-price">₹330</span></div>
                    <div class="menu-row"><span class="dish-name">Prawns Manchuria</span><span class="dish-price">₹330</span></div>
                    <div class="menu-row"><span class="dish-name">Prawns Fry</span><span class="dish-price">₹320</span></div>
                    <div class="menu-row"><span class="dish-name">Mutton Fry</span><span class="dish-price">₹360</span></div>
                    <div class="menu-row"><span class="dish-name">Mutton Keema Balls</span><span class="dish-price">₹350</span></div>
                    <div class="menu-row"><span class="dish-name">Egg Chilli</span><span class="dish-price">₹150</span></div>
                    <div class="menu-row"><span class="dish-name">Egg 65</span><span class="dish-price">₹150</span></div>
                    <div class="menu-row"><span class="dish-name">Egg Manchuria</span><span class="dish-price">₹150</span></div>
                    <div class="menu-row"><span class="dish-name">Egg Boiled (2)</span><span class="dish-price">₹30</span></div>
                    <div class="menu-row"><span class="dish-name">Egg Omelette</span><span class="dish-price">₹50</span></div>
                </div>
            </div>

            <!-- BIRIYANI SELECTIONS -->
            <div class="menu-section">
                <div class="section-header">Royal Biryani Heritage</div>
                <div class="grid-container">
                    <div class="menu-row"><span class="dish-name">Chicken Full Biriyani</span><span class="dish-price">₹300</span></div>
                    <div class="menu-row"><span class="dish-name">Chicken Dum Biriyani</span><span class="dish-price">₹240</span></div>
                    <div class="menu-row"><span class="dish-name">Chicken Fry Biriyani</span><span class="dish-price">₹240</span></div>
                    <div class="menu-row"><span class="dish-name">Mini Fry Biriyani</span><span class="dish-price">₹180</span></div>
                    <div class="menu-row"><span class="dish-name">Mughali Biriyani</span><span class="dish-price">₹310</span></div>
                    <div class="menu-row"><span class="dish-name">Lollypop Biriyani</span><span class="dish-price">₹320</span></div>
                    <div class="menu-row"><span class="dish-name">SPL Chicken Biriyani</span><span class="dish-price">₹310</span></div>
                    <div class="menu-row"><span class="dish-name">SPL Prawn Biriyani</span><span class="dish-price">₹350</span></div>
                    <div class="menu-row"><span class="dish-name">Prawn Biriyani</span><span class="dish-price">₹310</span></div>
                    <div class="menu-row"><span class="dish-name">Fish Biriyani</span><span class="dish-price">₹320</span></div>
                    <div class="menu-row"><span class="dish-name">Mutton Biriyani</span><span class="dish-price">₹380</span></div>
                    <div class="menu-row"><span class="dish-name">Manohar Spl Biriyani</span><span class="dish-price">₹330</span></div>
                    <div class="menu-row"><span class="dish-name">Chicken Potlam Biriyani</span><span class="dish-price">₹320</span></div>
                    <div class="menu-row"><span class="dish-name">Mixed Biriyani (Spl)</span><span class="dish-price">₹350</span></div>
                    <div class="menu-row"><span class="dish-name">Egg Biriyani</span><span class="dish-price">₹180</span></div>
                    <div class="menu-row"><span class="dish-name">Kaju Biriyani</span><span class="dish-price">₹260</span></div>
                    <div class="menu-row"><span class="dish-name">Veg Biriyani</span><span class="dish-price">₹180</span></div>
                    <div class="menu-row"><span class="dish-name">Paneer Biriyani</span><span class="dish-price">₹230</span></div>
                    <div class="menu-row"><span class="dish-name">Mushroom Biriyani</span><span class="dish-price">₹230</span></div>
                </div>
            </div>

            <!-- MANDI SPECIALS -->
            <div class="menu-section">
                <div class="section-header">Premium Mandi Platters</div>
                <div class="grid-container">
                    <div class="menu-row"><span class="dish-name">Chicken Full Mandi</span><span class="dish-price">₹1199</span></div>
                    <div class="menu-row"><span class="dish-name">Chicken Half Mandi</span><span class="dish-price">₹699</span></div>
                    <div class="menu-row"><span class="dish-name">Mutton Roasted Mandi</span><span class="dish-price">₹1900</span></div>
                    <div class="menu-row"><span class="dish-name">Mixed Full Mandi</span><span class="dish-price">₹1699</span></div>
                    <div class="menu-row"><span class="dish-name">Mixed Jumbo Mandi</span><span class="dish-price">₹1899</span></div>
                    <div class="menu-row"><span class="dish-name">Prawns Full Mandi</span><span class="dish-price">₹1799</span></div>
                </div>
            </div>

            <!-- MAIN COURSE CURRIES (NON-VEG) -->
            <div class="menu-section">
                <div class="section-header">Gourmet Non-Veg Curries</div>
                <div class="grid-container">
                    <div class="menu-row"><span class="dish-name">Chicken Curry (Andhra Style)</span><span class="dish-price">₹230</span></div>
                    <div class="menu-row"><span class="dish-name">Chicken Fry (Andhra Style)</span><span class="dish-price">₹240</span></div>
                    <div class="menu-row"><span class="dish-name">Butter Chicken</span><span class="dish-price">₹260</span></div>
                    <div class="menu-row"><span class="dish-name">Mughalali Chicken Curry</span><span class="dish-price">₹250</span></div>
                    <div class="menu-row"><span class="dish-name">Chicken Tikka Masala</span><span class="dish-price">₹250</span></div>
                    <div class="menu-row"><span class="dish-name">Kadai Chicken</span><span class="dish-price">₹230</span></div>
                    <div class="menu-row"><span class="dish-name">Methi Chicken</span><span class="dish-price">₹240</span></div>
                    <div class="menu-row"><span class="dish-name">Mutton Curry</span><span class="dish-price">₹340</span></div>
                    <div class="menu-row"><span class="dish-name">Fish Curry</span><span class="dish-price">₹280</span></div>
                    <div class="menu-row"><span class="dish-name">Prawns Curry</span><span class="dish-price">₹310</span></div>
                    <div class="menu-row"><span class="dish-name">Egg Masala Curry</span><span class="dish-price">₹130</span></div>
                </div>
            </div>

            <!-- ROTI & NAAN -->
            <div class="menu-section">
                <div class="section-header">Indian Breads & Tandoor</div>
                <div class="grid-container">
                    <div class="menu-row"><span class="dish-name">Roti</span><span class="dish-price">₹20</span></div>
                    <div class="menu-row"><span class="dish-name">Butter Roti</span><span class="dish-price">₹25</span></div>
                    <div class="menu-row"><span class="dish-name">Naan</span><span class="dish-price">₹35</span></div>
                    <div class="menu-row"><span class="dish-name">Butter Naan</span><span class="dish-price">₹45</span></div>
                    <div class="menu-row"><span class="dish-name">Garlic Naan</span><span class="dish-price">₹60</span></div>
                    <div class="menu-row"><span class="dish-name">Rumali Roti</span><span class="dish-price">₹25</span></div>
                    <div class="menu-row"><span class="dish-name">Pulka</span><span class="dish-price">₹15</span></div>
                </div>
            </div>

            <!-- FRIED RICE & NOODLES -->
            <div class="menu-section">
                <div class="section-header">Rice & Noodles Wok</div>
                <div class="grid-container">
                    <div class="menu-row"><span class="dish-name">Veg Fried Rice / Noodles</span><span class="dish-price">₹130</span></div>
                    <div class="menu-row"><span class="dish-name">Egg Fried Rice / Noodles</span><span class="dish-price">₹140</span></div>
                    <div class="menu-row"><span class="dish-name">Chicken Fried Rice / Noodles</span><span class="dish-price">₹180</span></div>
                    <div class="menu-row"><span class="dish-name">Schzwan Chicken Fried Rice</span><span class="dish-price">₹190</span></div>
                    <div class="menu-row"><span class="dish-name">Jeera Rice</span><span class="dish-price">₹140</span></div>
                    <div class="menu-row"><span class="dish-name">Kaju Fried Rice</span><span class="dish-price">₹220</span></div>
                </div>
            </div>

            <!-- VEG STARTERS & CURRIES -->
            <div class="menu-section">
                <div class="section-header">Exquisite Vegetarian Selection</div>
                <div class="grid-container">
                    <div class="menu-row"><span class="dish-name">Veg Manchuria</span><span class="dish-price">₹190</span></div>
                    <div class="menu-row"><span class="dish-name">Chilly Paneer</span><span class="dish-price">₹230</span></div>
                    <div class="menu-row"><span class="dish-name">Paneer 65</span><span class="dish-price">₹230</span></div>
                    <div class="menu-row"><span class="dish-name">Chilly Mushroom</span><span class="dish-price">₹210</span></div>
                    <div class="menu-row"><span class="dish-name">Mushroom 65</span><span class="dish-price">₹210</span></div>
                    <div class="menu-row"><span class="dish-name">Paneer Butter Masala</span><span class="dish-price">₹230</span></div>
                    <div class="menu-row"><span class="dish-name">Kaju Mushroom Curry</span><span class="dish-price">₹240</span></div>
                    <div class="menu-row"><span class="dish-name">Kaju Paneer Curry</span><span class="dish-price">₹250</span></div>
                    <div class="menu-row"><span class="dish-name">Mix Veg Curry</span><span class="dish-price">₹180</span></div>
                    <div class="menu-row"><span class="dish-name">Dal Tadka</span><span class="dish-price">₹120</span></div>
                    <div class="menu-row"><span class="dish-name">Dal Fry</span><span class="dish-price">₹110</span></div>
                </div>
            </div>

        </div>

        <footer>
            <p>// MANOHAR ROYAL LUXURY PORTFOLIO © 2026 //</p>
        </footer>
    </div>

    <script>
        function openMenu() {
            const screen = document.getElementById('welcome-screen');
            const content = document.getElementById('main-content');
            
            screen.style.opacity = '0';
            screen.style.transform = 'scale(1.05) translateY(-20px)';
            
            setTimeout(() => {
                screen.style.display = 'none';
                content.style.display = 'block';
                setTimeout(() => {
                    content.style.opacity = '1';
                }, 50);
            }, 1200);
        }
    </script>
</body>
</html>
